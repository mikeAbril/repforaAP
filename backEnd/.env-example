# ============================================================
# GOOGLE DRIVE — OAuth2 (3 variables obligatorias)
# ============================================================
# Paso 1: Ve a Google Cloud Console → APIs y Servicios → Credenciales
#         → ID de cliente OAuth 2.0 → copia estos dos valores:
GOOGLE_OAUTH_CLIENT_ID=aaa
GOOGLE_OAUTH_CLIENT_SECRET=aaa

# Paso 2: Ejecuta "node utils/setupDriveAuth.js" y pega el código generado aquí:
GOOGLE_OAUTH_REFRESH_TOKEN=aaa

# Paso 3: ID de la carpeta raíz en Google Drive donde se guardan los certificados
GOOGLE_DRIVE_FOLDER_ID=19eE4cFG_FFPeXAaUW93K5UQ0KeWG8GNX

# ============================================================
# OTROS
# ============================================================
# Clave de 32 caracteres para encriptación interna (API Keys de supervisores)
CRYPTO_KEY=12345678901234567890123456789012


# ============================================================
# SCRAPERS
# ============================================================
# false = navegador visible (desarrollo/debug)
# true  = sin interfaz gráfica (producción/servidor)
# Si no se define, por defecto es true
HEADLESS=false

# ============================================================
# NODEMAILER (Configuración de correo)
# ============================================================
MAIL_USER=[EMAIL_ADDRESS]
MAIL_PASS=tu_password_de_aplicacion