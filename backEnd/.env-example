# ============================================================
# SERVIDOR
# ============================================================
PORT=3000
JWT_SECRET=tu_clave_secreta_para_tokens
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# ============================================================
# BASE DE DATOS (MongoDB Atlas)
# ============================================================
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db

# ============================================================
# GOOGLE DRIVE — OAuth2
# Ver guía de configuración en SYSTEM_DOCUMENTATION.md (Sección 4)
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-tu_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=1//tu_refresh_token_generado
# Carpeta raíz en Drive (vacío = se crea automáticamente)
GOOGLE_DRIVE_FOLDER_ID=

# ============================================================
# 2CAPTCHA (Resolución automática de captchas)
# ============================================================
# Clave de 32 caracteres para encriptación interna (API Keys de supervisores)
CRYPTO_KEY=12345678901234567890123456789012


# ============================================================
# SCRAPERS
# false = navegador visible (desarrollo) | true = invisible (producción)
# Por defecto: true
# ============================================================
HEADLESS=false
